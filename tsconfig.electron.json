{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "CommonJS",
    "moduleResolution": "node10",
    "ignoreDeprecations": "5.0",
    "esModuleInterop": true,
    "rootDir": ".",
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist"
  },
  "include": ["electron", "shared"]
}